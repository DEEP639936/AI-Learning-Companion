# ─── Database ──────────────────────────────────────────────────────
# For local development (SQLite):
DATABASE_URL=file:./db/custom.db

# For production on Vercel, use a cloud database:
# DATABASE_URL=postgresql://user:password@host:5432/mentora
# (See DEPLOYMENT.md for Supabase setup instructions)

# ─── AI Backend Configuration ─────────────────────────────────────
# REQUIRED for external deployment (GitHub → Vercel)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🆓 MULTIPLE API KEYS = MORE FREE REQUESTS!
# Separate keys with commas — the app rotates automatically.
# Example: OPENAI_API_KEY=nvapi-key1,nvapi-key2,nvapi-key3
# This gives you 3× the free quota (3,000 credits instead of 1,000)!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# ── Option 1: Nvidia DeepSeek V4 Pro (RECOMMENDED ✅) ──────────────
# Sign up: https://build.nvidia.com → search "deepseek-v4-pro" → Get API Key
# Free: 1,000 credits/signup + 40 requests/min. No credit card needed.
# Cost after free: ~$0.30/1M input tokens, $0.50/1M output tokens
OPENAI_API_KEY=nvapi-your-key-here
OPENAI_BASE_URL=nvidia://
OPENAI_MODEL=deepseek-ai/deepseek-v4-pro

# ── Option 2: Nvidia DeepSeek V4 Flash (CHEAPER, faster) ──────────
# Sign up: https://build.nvidia.com → search "deepseek-v4-flash" → Get API Key
# Free: same 1,000 credits. Cost after: ~$0.04/1M input tokens!
# OPENAI_API_KEY=nvapi-your-key-here
# OPENAI_BASE_URL=nvidia://
# OPENAI_MODEL=deepseek-ai/deepseek-v4-flash

# ── Option 3: Groq (FASTEST, generous free tier) ──────────────────
# Sign up: https://console.groq.com
# Free: 14,400 requests/day forever. Cost after: ~$0.59/1M tokens
# OPENAI_API_KEY=gsk_your-groq-key-here
# OPENAI_BASE_URL=groq://
# OPENAI_MODEL=llama-3.3-70b-versatile

# ── Option 4: OpenAI (best quality, paid only) ─────────────────────
# Sign up: https://platform.openai.com/api-keys
# Cost: ~$0.15/1M input tokens (gpt-4o-mini)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=openai://
# OPENAI_MODEL=gpt-4o-mini
